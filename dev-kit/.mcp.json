{
  "mcpServers": {
    "devkit-mcp": {
      "type": "stdio",
      "command": "devkit-mcp",
      "args": [
        "--solution",
        "${SOLUTION_PATH}"
      ],
      "env": {
        "Neo4j__Uri": "${NEO4J_URI}",
        "Neo4j__Username": "${NEO4J_USERNAME}",
        "Neo4j__Password": "${NEO4J_PASSWORD}"
      }
    },
    "atlassian": {
      "type": "sse",
      "url": "https://mcp.atlassian.com/v1/sse"
    }
  }
}
