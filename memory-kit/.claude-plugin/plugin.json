{
  "name": "memory-kit",
  "version": "1.0.5",
  "description": "Intelligent memory management meta-kit for Claude Code. Auto-capture corrections via hooks, semantic retrieval, deduplication, and memory lifecycle management powered by the memory-mcp server.",
  "author": {
    "name": "Gino Poitier",
    "email": "gino.poitier@gmail.com"
  },
  "homepage": "https://github.com/ginopoitier/claude-plugins/tree/main/memory-kit",
  "repository": "https://github.com/ginopoitier/claude-plugins",
  "license": "MIT",
  "keywords": ["memory", "meta", "auto-capture", "hooks", "knowledge-management", "persistence"],
  "mcpServers": {
    "memory-mcp": {
      "command": "npx",
      "args": ["-y", "@ginopoitier/memory-mcp"],
      "env": {
        "MEMORY_BASE_PATH": "~/.claude/projects"
      }
    }
  }
}
